<horizontal pad='2' spacing='1.5' child-expand-width='false' active='~is-not-loading'>
	<vertical pref-width='65' bg='panel-top' skew='0'>
    <text text='Daily' align='Center' font-size='5'/>
    <custom-list id='daily-list' contents='daily-cells'  visible-cells='2' cell-size='12' _children='~mission-cell'/>
	</vertical>
	<vertical pref-width='65' bg='panel-top' skew='0'>
		<text text='Weekly' align='Center' font-size='5'/>
		<custom-list id='weekly-list' contents='weekly-cells' visible-cells='3' cell-size='12' _children='~mission-cell'/>
	</vertical>
</horizontal>